# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored — never commit real keys. In Docker/production, these
# are supplied via environment variables / secrets, never baked into the image.

ENV=development
CORS_ORIGINS=http://localhost:3000,http://10.0.2.2

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to the downloaded service account JSON (Firebase Console > Project
# settings > Service accounts > Generate new private key). Save it as
# backend/firebase-service-account.json — never commit this file. Works
# for both local runs and Docker (docker-compose mounts it to the same
# relative path inside the container's WORKDIR).
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# AI provider ("gemini" or "openai")
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# Stripe (SECRET key — backend only, never sent to Flutter)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PREMIUM_MONTHLY=price_xxx
STRIPE_PRICE_ID_PREMIUM_YEARLY=price_xxx

# Rate limiting
AI_RATE_LIMIT_PER_MINUTE=10
