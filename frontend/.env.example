# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored — never commit real keys.
#
# NOTE: only client-safe values belong here. Stripe SECRET key, AI provider
# keys, and the Firebase service account MUST stay in the backend's .env —
# never in this file.

ENV=development

# FastAPI backend base URL.
# Android emulator -> host machine: http://10.0.2.2:8000
# iOS simulator -> host machine:    http://127.0.0.1:8000
# Physical device: use your machine's LAN IP, e.g. http://192.168.1.10:8000
API_BASE_URL=http://10.0.2.2:8000

# Firebase Web/Android config values (from Firebase console -> Project settings).
# These are public client identifiers, not secrets.
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=

# Stripe PUBLISHABLE key only (starts with pk_). Never put the secret key (sk_) here.
STRIPE_PUBLISHABLE_KEY=
